<?xml version="1.1" encoding="UTF-8"?>

<channel name="xfce4-keyboard-shortcuts" version="1.0">
  <property name="commands" type="empty">
    <property name="default" type="empty">
      <property name="&lt;Super&gt;Return" type="empty"/>
      <property name="&lt;Super&gt;d" type="empty"/>
      <property name="&lt;Super&gt;e" type="empty"/>
      <property name="&lt;Super&gt;q" type="empty"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;e" type="empty"/>
      <property name="&lt;Super&gt;Print" type="empty"/>
      <property name="Print" type="empty"/>
    </property>
    <property name="custom" type="empty">
      <!-- Launcher Aplikasi Standar Niri -->
      <property name="&lt;Super&gt;Return" type="string" value="exo-open --launch TerminalEmulator"/>
      <property name="&lt;Super&gt;d" type="string" value="xfce4-appfinder"/>
      <property name="&lt;Super&gt;e" type="string" value="thunar"/>
      
      <!-- Pengelolaan Sesi Niri (Quit / Power Menu) -->
      <property name="&lt;Super&gt;&lt;Shift&gt;e" type="string" value="xfce4-session-logout"/>
      
      <!-- Screenshot Standar Niri -->
      <property name="Print" type="string" value="xfce4-screenshooter -r"/>
      <property name="&lt;Super&gt;Print" type="string" value="xfce4-screenshooter"/>
      <property name="&lt;Alt&gt;Print" type="string" value="xfce4-screenshooter -w"/>

      <property name="override" type="bool" value="true"/>
    </property>
  </property>
  <property name="xfwm4" type="empty">
    <property name="default" type="empty">
      <!-- Dikosongkan agar sistem membaca custom property dengan benar -->
    </property>
    <property name="custom" type="empty">
      <!-- Jendela Aktif & Layouting (Standar Niri) -->
      <property name="&lt;Super&gt;q" type="string" value="close_window_key"/>
      <property name="&lt;Super&gt;f" type="string" value="maximize_window_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;f" type="string" value="fullscreen_key"/>
      <property name="&lt;Super&gt;c" type="string" value="popup_menu_key"/>

      <!-- Navigasi Fokus Jendela / Kolom (Niri: Super + Arrow/HJKL) -->
      <property name="&lt;Super&gt;Left" type="string" value="left_key"/>
      <property name="&lt;Super&gt;h" type="string" value="left_key"/>
      <property name="&lt;Super&gt;Right" type="string" value="right_key"/>
      <property name="&lt;Super&gt;l" type="string" value="right_key"/>
      <property name="&lt;Super&gt;Down" type="string" value="down_key"/>
      <property name="&lt;Super&gt;j" type="string" value="down_key"/>
      <property name="&lt;Super&gt;Up" type="string" value="up_key"/>
      <property name="&lt;Super&gt;k" type="string" value="up_key"/>

      <!-- Memindahkan Posisi Jendela / Kolom (Niri: Super + Shift + Arrow/HJKL) -->
      <property name="&lt;Super&gt;&lt;Shift&gt;Left" type="string" value="move_window_left_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;h" type="string" value="move_window_left_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;Right" type="string" value="move_window_right_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;l" type="string" value="move_window_right_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;Down" type="string" value="move_window_down_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;j" type="string" value="move_window_down_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;Up" type="string" value="move_window_up_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;k" type="string" value="move_window_up_key"/>

      <!-- Navigasi Workspace (Niri: Super + U/I untuk Prev/Next Workspace) -->
      <property name="&lt;Super&gt;i" type="string" value="prev_workspace_key"/> <!-- MEMPERBAIKI PREV WORKSPACE -->
      <property name="&lt;Super&gt;u" type="string" value="next_workspace_key"/> <!-- MEMPERBAIKI NEXT WORKSPACE -->
      
      <property name="&lt;Super&gt;1" type="string" value="workspace_1_key"/>
      <property name="&lt;Super&gt;2" type="string" value="workspace_2_key"/>
      <property name="&lt;Super&gt;3" type="string" value="workspace_3_key"/>
      <property name="&lt;Super&gt;4" type="string" value="workspace_4_key"/>
      <property name="&lt;Super&gt;5" type="string" value="workspace_5_key"/>
      <property name="&lt;Super&gt;6" type="string" value="workspace_6_key"/>
      <property name="&lt;Super&gt;7" type="string" value="workspace_7_key"/>
      <property name="&lt;Super&gt;8" type="string" value="workspace_8_key"/>
      <property name="&lt;Super&gt;9" type="string" value="workspace_9_key"/>

      <!-- Memindahkan Jendela ke Workspace Lain (Niri: Super + Shift + U/I) -->
      <property name="&lt;Super&gt;&lt;Shift&gt;u" type="string" value="move_window_prev_workspace_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;i" type="string" value="move_window_next_workspace_key"/>
      
      <property name="&lt;Super&gt;&lt;Shift&gt;1" type="string" value="move_window_workspace_1_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;2" type="string" value="move_window_workspace_2_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;3" type="string" value="move_window_workspace_3_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;4" type="string" value="move_window_workspace_4_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;5" type="string" value="move_window_workspace_5_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;6" type="string" value="move_window_workspace_6_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;7" type="string" value="move_window_workspace_7_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;8" type="string" value="move_window_workspace_8_key"/>
      <property name="&lt;Super&gt;&lt;Shift&gt;9" type="string" value="move_window_workspace_9_key"/>

      <!-- Pengaturan Lebar/Tinggi Kolom (Niri: Super + R untuk reset, Super + Minus/Equal) -->
      <property name="&lt;Super&gt;r" type="string" value="tile_down_key"/>
      <property name="&lt;Super&gt;minus" type="string" value="lower_window_key"/>
      <property name="&lt;Super&gt;equal" type="string" value="raise_window_key"/>

      <property name="override" type="bool" value="true"/>
    </property>
  </property>
  <property name="providers" type="array">
    <value type="string" value="xfwm4"/>
    <value type="string" value="commands"/>
  </property>
</channel>

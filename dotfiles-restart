#!/usr/bin/env bash

# ==============================================================================
# ⚔  DOTFILES MANAGER (BAT-STYLE BOX • CENTERED)  ⚔
# ==============================================================================

# Definisi Warna
R='\033[1;31m' # Red
G='\033[1;32m' # Green
C='\033[1;36m' # Cyan
W='\033[1;37m' # White Bold
D='\033[0;90m' # Dark Grey (Garis Kotak)
NC='\033[0m'   # No Color

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SOURCE_DIR="$SCRIPT_DIR/src/config"
TARGET_DIR="$HOME/.config"

if [ ! -d "$SOURCE_DIR" ]; then
	echo -e "${R}Error: Folder Source tidak ditemukan di $SOURCE_DIR${NC}"
	exit 1
fi

mkdir -p "$TARGET_DIR"

# --- FUNGSI FORMATTING TENGAH (CENTERED UI) ---

# Disesuaikan presisinya menjadi 58 agar pas dengan total lebar kolom content row
BOX_WIDTH=58

get_center_padding() {
	local term_width=$(tput cols 2>/dev/null || echo 80)
	local padding=$(((term_width - BOX_WIDTH) / 2))
	if [ $padding -lt 0 ]; then padding=0; fi
	echo "$padding"
}

print_border_line() {
	local type="$1" # top, bottom
	local pad=$(get_center_padding)
	local line="────────────────────────────────────────────────────────"

	printf "%${pad}s" ""
	if [ "$type" == "top" ]; then
		echo -e "${D}┌${line}┐${NC}"
	else
		echo -e "${D}└${line}┘${NC}"
	fi
}

print_content_row() {
	local left_text="$1"
	local right_text="$2"
	local right_color="$3"
	local pad=$(get_center_padding)

	printf "%${pad}s" ""
	# Total lebar: 1(│) + 2(spaces) + 32 + 1(space) + 20 + 1(space) + 1(│) = 58
	printf "${D}│${NC}  ${C}%-32s${NC} ${right_color}%-20s${NC} ${D}│${NC}\n" "$left_text" "$right_text"
}

print_header() {
	local title="$1"
	local term_width=$(tput cols 2>/dev/null || echo 80)
	local title_len=${#title}
	local pad=$(((term_width - title_len) / 2))
	if [ $pad -lt 0 ]; then pad=0; fi

	clear
	echo ""
	printf "%${pad}s" ""
	echo -e "${W}${title}${NC}"
	print_border_line "top"
}

get_now_seconds() {
	# Fallback yang aman untuk cross-platform (Linux & macOS) dibanding menggunakan %N
	date +%s
}

# --- LOGIKA UTAMA ---

if [ "$1" == "reset" ]; then
	# ==========================================
	# FEATURE: RESET MODE
	# ==========================================
	print_header "⚡ DOTFILES RESET ENGINE"

	# Reset folder target
	shopt -s nullglob
	for dir in "$SOURCE_DIR"/*; do
		if [ -d "$dir" ]; then
			folder_name=$(basename "$dir")

			# Pengecualian khusus VS Code & Neovim saat Reset agar tidak merusak local state
			if [[ "$folder_name" == "Code" || "$folder_name" == "Code - OSS" ]]; then
				if [ -f "$TARGET_DIR/$folder_name/User/settings.json" ]; then
					rm -f "$TARGET_DIR/$folder_name/User/settings.json"
					print_content_row ".config/$folder_name/.../settings.json" "DELETED" "$R"
				fi
			elif [[ "$folder_name" == "nvim" ]]; then
				# Untuk nvim, kita bersihkan konfigurasinya saja, biarkan lockfile/state tetap ada
				find "$TARGET_DIR/$folder_name" -maxdepth 1 -type f -name "*.lua" -exec rm -f {} \;
				print_content_row ".config/$folder_name (Config Cleaned)" "RESET" "$R"
			else
				if [ -d "$TARGET_DIR/$folder_name" ]; then
					rm -rf "$TARGET_DIR/$folder_name"
					print_content_row ".config/$folder_name" "DELETED" "$R"
				fi
			fi
		fi
	done

	# Reset dotfiles home
	shopt -s dotglob nullglob
	for item in "$SOURCE_DIR"/*; do
		if [ -f "$item" ]; then
			item_name=$(basename "$item")
			if [[ "$item_name" == .* ]]; then target_name="$item_name"; else target_name=".$item_name"; fi
			if [ -f "$HOME/$target_name" ]; then
				rm -f "$HOME/$target_name"
				print_content_row "$target_name" "DELETED" "$R"
			fi
		fi
	done

	print_border_line "bottom"
	echo ""
	exit 0

else
	# ==========================================
	# FEATURE: SYNC MODE (REPLACE TOTAL)
	# ==========================================
	print_header "⚔  DOTFILES DEPLOYMENT ENGINE"

	start_time=$(get_now_seconds)

	# 1. Mengganti Folder di ~/.config
	shopt -s nullglob
	for dir in "$SOURCE_DIR"/*; do
		if [ -d "$dir" ]; then
			folder_name=$(basename "$dir")
			target_path="$TARGET_DIR/$folder_name"

			# CASE 1: VS CODE / CODE - OSS
			if [[ "$folder_name" == "Code" || "$folder_name" == "Code - OSS" ]]; then
				mkdir -p "$target_path/User"

				if [ -f "$dir/User/settings.json" ]; then
					cp -f "$dir/User/settings.json" "$target_path/User/settings.json"
				elif [ -f "$dir/settings.json" ]; then
					cp -f "$dir/settings.json" "$target_path/User/settings.json"
				fi

				if [ -f "$dir/User/keybindings.json" ]; then
					cp -f "$dir/User/keybindings.json" "$target_path/User/keybindings.json"
				elif [ -f "$dir/keybindings.json" ]; then
					cp -f "$dir/keybindings.json" "$target_path/User/keybindings.json"
				fi

				print_content_row ".config/$folder_name (Settings)" "UPDATED" "$G"

			# CASE 2: NEOVIM (Safe Merge - Mencegah Crash Lockfile)
			elif [[ "$folder_name" == "nvim" ]]; then
				mkdir -p "$target_path"

				# Copy file konfigurasi baru secara overwrite tanpa menghapus isi folder target (rm -rf)
				# Gunakan rsync jika ada, atau cp -rf dengan mengabaikan file lockfile dari source jika ada
				if hash rsync 2>/dev/null; then
					rsync -av --exclude='*lock.json' --exclude='lazy-lock.json' "$dir/" "$target_path/" &>/dev/null
				else
					cp -rf "$dir"/* "$target_path/" 2>/dev/null
				fi

				print_content_row ".config/$folder_name (Safe Sync)" "UPDATED" "$G"

			# CASE 3: FOLDER LAIN (Wipe & Replace Murni)
			else
				rm -rf "$target_path"
				mkdir -p "$target_path"
				cp -rf "$dir"/* "$target_path/"

				print_content_row ".config/$folder_name" "WIPED & REPLACED" "$G"
			fi
		fi
	done

	# 2. Mengganti File Dotfiles di $HOME
	shopt -s dotglob nullglob
	for item in "$SOURCE_DIR"/*; do
		if [ -f "$item" ]; then
			item_name=$(basename "$item")

			if [[ "$item_name" == .* ]]; then
				target_name="$item_name"
			else
				target_name=".$item_name"
			fi
			target_path="$HOME/$target_name"

			rm -f "$target_path"
			cp -f "$item" "$target_path"

			print_content_row "$target_name" "WIPED & REPLACED" "$G"
		fi
	done

	# Tutup panel utama
	print_border_line "bottom"

	end_time=$(get_now_seconds)
	duration=$((end_time - start_time))

	# Footer Metadata ringkas
	echo ""
	term_width=$(tput cols 2>/dev/null || echo 80)
	footer_text="Finished in ${duration}s • System Updated"
	footer_pad=$(((term_width - ${#footer_text}) / 2))
	if [ $footer_pad -lt 0 ]; then footer_pad=0; fi
	printf "%${footer_pad}s" ""
	echo -e "${D}${footer_text}${NC}"
	echo ""
fi
